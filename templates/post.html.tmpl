<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{SUMMARY}}">
    <meta name="keywords" content="blog, groff, OpenBSD, minimalist, {{TITLE}}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{TITLE}}">
    <meta property="og:description" content="{{SUMMARY}}">
    <meta property="og:url" content="{{POST_URL}}">
    <meta property="og:image" content="{{SITE_URL}}/images/profile.jpg">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{TITLE}}">
    <meta name="twitter:description" content="{{SUMMARY}}">
    <title>{{BLOG_NAME}} - {{TITLE}}</title>
    <link rel="canonical" href="{{POST_URL}}">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/css/vars.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/font-awesome.min.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/base.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/prism.css?{{TIMESTAMP}}">
    <link rel="alternate" type="application/rss+xml" title="{{BLOG_NAME}}" href="/rss.xml">
    <link rel="alternate" type="application/atom+xml" title="{{BLOG_NAME}}" href="/atom.xml">
</head>
<body class="{{PAGE_TYPE}}">
    <div class="sidebar">
        <img src="/images/profile.jpg" alt="Profile Picture" class="profile-pic">
        <h3>Links</h3>
        <div class="sidebar-links">
            {{SIDEBAR_HTML}}
        </div>
    </div>
    <main class="main">
        <article class="post">
            <header class="post-header">
                <h1 data-text="{{TITLE}}">{{TITLE}}</h1>
                <div class="post-meta">By {{AUTHOR}}, {{DATE}}{{READ_TIME}}</div>
                {{TAG_LINKS}}
                <hr>
            </header>
            <div class="post-content">
                CONTENT_PLACEHOLDER
            </div>
        </article>
        <section class="comments">
            <script src="https://giscus.app/client.js"
                    data-repo="ekollof/andrath.nl"
                    data-repo-id="R_kgDOOQE6Vg"
                    data-category="Announcements"
                    data-category-id="DIC_kwDOOQE6Vs4C3mT7"
                    data-mapping="pathname"
                    data-strict="1"
                    data-reactions-enabled="1"
                    data-emit-metadata="1"
                    data-input-position="bottom"
                    data-theme="dark"
                    data-lang="en"
                    data-loading="lazy"
                    crossorigin="anonymous"
                    async>
            </script>
        </section>
        <nav class="navigation">
            <div class="prev">{{PREV_LINK}}</div>
            <div class="index"><a href="/index.html">Back to Index</a></div>
            <div class="next">{{NEXT_LINK}}</div>
            <div class="source-link">{{SOURCE_LINK}}</div>
        </nav>
    </main>
    <script src="/js/prism.js"></script>
    <script src="/js/vim-navigation.js"></script>
</body>
</html>

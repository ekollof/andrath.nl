<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{BLOG_NAME}} - A minimalist blog built with groff on OpenBSD.">
    <meta name="keywords" content="blog, groff, OpenBSD, minimalist">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{BLOG_NAME}}">
    <meta property="og:description" content="{{BLOG_NAME}} - {{SITE_SUBTITLE}}">
    <meta property="og:url" content="{{SITE_URL}}/">
    <meta property="og:image" content="{{SITE_URL}}/images/profile.jpg">
    <title>{{BLOG_NAME}}</title>
    <link rel="canonical" href="{{SITE_URL}}/">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/css/vars.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/font-awesome.min.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/base.css?{{TIMESTAMP}}">
    <link rel="stylesheet" href="/css/prism.css?{{TIMESTAMP}}">
    <link rel="alternate" type="application/rss+xml" title="{{BLOG_NAME}}" href="/rss.xml">
    <link rel="alternate" type="application/atom+xml" title="{{BLOG_NAME}}" href="/atom.xml">
</head>
<body class="{{PAGE_TYPE}}">
    <div class="sidebar">
        <img src="/images/profile.jpg" alt="Profile Picture" class="profile-pic">
        <h3>Links</h3>
        <div class="sidebar-links">
            {{SIDEBAR_HTML}}
        </div>
    </div>
    <main class="main">
        <h1>{{BLOG_NAME}}</h1>
        <h2 class="site-subtitle">{{SITE_SUBTITLE}}</h2>
        <div class="site-description">{{SITE_DESCRIPTION_GROFF}}</div>
        <ul class="post-list">
            {{POST_LIST}}
        </ul>
    </main>
    <script src="/js/prism.js"></script>
    <script src="/js/vim-navigation.js"></script>
    <script src="/js/terminal-scroll.js"></script>
    <script src="/js/crt-effects.js"></script>
</body>
</html>
